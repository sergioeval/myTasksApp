# Copy this file to:  .streamlit/secrets.toml
# Never commit secrets.toml (it is listed in .gitignore).
#
# For Streamlit Community Cloud: paste the same [auth] block in the app Secrets UI.
#
# Use a strong password and serve the app over HTTPS in production.

[auth]
username = "your_username"
password = "your_strong_password"

# PostgreSQL (Supabase). Use the database password from Project Settings → Database.
# Pooler (port 6543) is fine for this app. Never commit the real password.
[postgres]
host = "aws-1-us-east-1.pooler.supabase.com"
port = 6543
database = "postgres"
user = "postgres.mcbiyaddqmmyfxxrsvpk"
password = "YOUR_SUPABASE_DB_PASSWORD"
sslmode = "require"
