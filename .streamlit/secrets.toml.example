# Copy this file to:  .streamlit/secrets.toml
# Never commit secrets.toml (it is listed in .gitignore).
#
# For Streamlit Community Cloud: paste the same [auth] block in the app Secrets UI.
#
# Use a strong password and serve the app over HTTPS in production.

[auth]
username = "your_username"
password = "your_strong_password"

# PostgreSQL (Supabase). Password: Project Settings → Database.
#
# Prefer the TRANSACTION POOLER below: Supabase's direct host (db.<ref>.supabase.co)
# is often IPv6-only; many networks have no IPv6 route → "Network is unreachable".
# The pooler resolves to IPv4 and works with the same DB password.
#
# Direct (IPv6-only on many projects): host db.mcbiyaddqmmyfxxrsvpk.supabase.co,
# port 5432, user postgres — use only if you have working IPv6 or Supabase IPv4 add-on.
[postgres]
host = "aws-1-us-east-1.pooler.supabase.com"
port = 6543
database = "postgres"
user = "postgres.mcbiyaddqmmyfxxrsvpk"
password = "YOUR_SUPABASE_DB_PASSWORD"
sslmode = "require"
